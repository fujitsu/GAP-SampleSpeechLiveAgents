<Window x:Class="SampleSpeechLiveAgents.Views.SettingsWindow"
        x:Name="window" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SampleSpeechLiveAgents.Views"
        xmlns:prop="clr-namespace:SampleSpeechLiveAgents.Properties"
        xmlns:converter="clr-namespace:SampleSpeechLiveAgents.Converters"
        xmlns:Common="clr-namespace:SampleSpeechLiveAgents.Commons" 
        mc:Ignorable="d"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        FontFamily="Meiryo UI"
        Title="{x:Static prop:Resources.Settings}"
        SizeToContent="Height" Width="550"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        DataContext="{Binding ViewModel, RelativeSource={RelativeSource Mode=Self}}"
        d:DataContext="{d:DesignInstance IsDesignTimeCreatable=False}">
    <Window.Resources>
        <converter:NegativeConverter x:Key="NegativeConverter"/>
    </Window.Resources>

    <Grid Margin="6,6,6,6" IsEnabled="{Binding IsBusy,Converter={StaticResource NegativeConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="4,0,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="{x:Static prop:Resources.TenantName}" VerticalAlignment="Center" Margin="0,0,0,0" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TenantName, Mode=TwoWay}" Height="34" VerticalContentAlignment="Center" Margin="0,2,0,2"/>
            <Label Grid.Row="1" Grid.Column="0" Content="{x:Static prop:Resources.ClientId}" VerticalAlignment="Center" Margin="0,0,0,0" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ClientId, Mode=TwoWay}" Height="34" VerticalContentAlignment="Center" Margin="0,2,0,2" />
            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="{x:Static prop:Resources.UseOSWebView}" IsChecked="{Binding IsUseOSWebView, Mode=TwoWay}" VerticalAlignment="Center" Margin="4,0,0,0" />
            <Label Grid.Row="3" Grid.Column="0" Content="{x:Static prop:Resources.AuthenticationType}" VerticalAlignment="Center" Margin="0,0,0,0" />
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton Content="{x:Static prop:Resources.AuthenticationTypePrompt}" IsChecked="{Binding IsPromptAuthentication, Mode=TwoWay}" GroupName="Authentication" Margin="4,0,4,0" />
                <RadioButton Content="{x:Static prop:Resources.AuthenticationTypeNonPrompt}" IsChecked="{Binding IsPromptAuthentication, Converter={StaticResource NegativeConverter}, Mode=OneWay}" GroupName="Authentication" Margin="4,0,4,0"/>
            </StackPanel>
            <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="{x:Static prop:Resources.AuthenticationTypeNonPrompt}" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <Label Grid.Row="5" Grid.Column="0" Content="{x:Static prop:Resources.ClientSecret}" VerticalAlignment="Center" Margin="10,0,0,0" />
            <PasswordBox Grid.Row="5" Grid.Column="1" Common:PasswordBoxHelper.Password="{Binding ClientSecret, Mode=TwoWay}" Height="34" VerticalContentAlignment="Center" Margin="0,2,0,2" />
            <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Content="Azure Speech Service" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <Label Grid.Row="7" Grid.Column="0" Content="Key" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding AzureSpeechKey, Mode=TwoWay}" Height="34" VerticalContentAlignment="Center" Margin="0,2,0,2" />
            <Label Grid.Row="8" Grid.Column="0" Content="Region" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding AzureSpeechRegion, Mode=TwoWay}" Height="34" VerticalContentAlignment="Center" Margin="0,2,0,2" />
        </Grid>
        <StackPanel Grid.Row="1" Margin="4,10,4,4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="0,0,5,0" Content="{x:Static prop:Resources.Save}" Width="88" Height="27"
                    FontWeight="Bold" FontSize="14" Background="White" 
				    Command="{Binding SaveCommand}"/>
            <Button Content="{x:Static prop:Resources.Cancel}" Margin="5,0,0,0" Width="88" Height="27"
                    FontWeight="Bold" FontSize="14" Background="White">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:CallMethodAction TargetObject="{Binding ElementName=window}" MethodName="Close" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>
        </StackPanel>
    </Grid>
</Window>
